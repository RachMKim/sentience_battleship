{
  "name": "battleship",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm run dev --prefix server",
    "dev:client": "npm run dev --prefix client",
    "build": "npm install --prefix server && npm install --prefix client && npm run build --prefix client && npm run build --prefix server",
    "start": "npm run start --prefix server",
    "install:all": "npm install && npm install --prefix server && npm install --prefix client",
    "db:migrate": "npm run db:migrate --prefix server",
    "db:generate": "npm run db:generate --prefix server",
    "test": "npm test --prefix server",
    "test:e2e": "npx playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "concurrently": "^9.1.0"
  }
}
